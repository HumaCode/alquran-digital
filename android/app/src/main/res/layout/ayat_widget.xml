<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_background">

    <!-- Header Row -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ayat Harian"
            android:textColor="#E6C485"
            android:textSize="12sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/widget_ayat_ref"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:text="QS. Al-Baqarah: 183"
            android:textColor="#8DA09C"
            android:textSize="11sp" />
    </RelativeLayout>

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp">

        <!-- Teks Arab -->
        <TextView
            android:id="@+id/widget_ayat_arab"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="كُتِبَ عَلَيْكُمُ الصِّيَامُ"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:gravity="right"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="4dp" />

        <!-- Teks Terjemahan -->
        <TextView
            android:id="@+id/widget_ayat_indo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Diwajibkan atas kamu berpuasa..."
            android:textColor="#8DA09C"
            android:textSize="11sp"
            android:gravity="left"
            android:maxLines="2"
            android:ellipsize="end" />
    </LinearLayout>
</LinearLayout>
