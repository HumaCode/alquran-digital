<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background">

    <!-- Background Watermark Star Ornamen -->
    <ImageView
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_gravity="right|center_vertical"
        android:layout_marginRight="-30dp"
        android:scaleType="fitCenter"
        android:src="@drawable/vector_star" />

    <!-- Corner Ornaments for Premium Islamic Aesthetics -->
    <ImageView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="left|top"
        android:scaleType="fitXY"
        android:src="@drawable/vector_corner_ornament" />

    <ImageView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="left|bottom"
        android:scaleType="fitXY"
        android:rotation="270"
        android:src="@drawable/vector_corner_ornament" />

    <ImageView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="right|top"
        android:scaleType="fitXY"
        android:rotation="90"
        android:src="@drawable/vector_corner_ornament" />

    <!-- Main Content Layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Row -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/widget_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tilawah Hari Ini"
                android:textColor="#E6C485"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/widget_streak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:text="🔥 0 Hari Streak"
                android:textColor="#FF9F1C"
                android:textSize="11sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Main Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp">
                <TextView
                    android:id="@+id/widget_progress_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 dari 10 ayat"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/widget_progress_percent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:text="0%"
                    android:textColor="#2EC4B6"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <ProgressBar
                android:id="@+id/widget_progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:progress="0"
                android:max="100"
                android:progressDrawable="@drawable/widget_progress_drawable" />
                
            <TextView
                android:id="@+id/widget_target_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Target harian Anda"
                android:textColor="#8DA09C"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
