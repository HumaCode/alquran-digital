<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Inner Card Container with Margin to prevent system clipping of rounded corners -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="6dp"
        android:background="@drawable/widget_background">

        <!-- Background Watermark Star Ornamen -->
        <ImageView
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_gravity="right|center_vertical"
            android:layout_marginRight="-30dp"
            android:scaleType="fitCenter"
            android:src="@drawable/vector_star" />

        <!-- Corner Ornaments inside the border stroke -->
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="left|top"
            android:layout_marginLeft="2dp"
            android:layout_marginTop="2dp"
            android:scaleType="fitXY"
            android:src="@drawable/vector_corner_ornament" />

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="left|bottom"
            android:layout_marginLeft="2dp"
            android:layout_marginBottom="2dp"
            android:scaleType="fitXY"
            android:rotation="270"
            android:src="@drawable/vector_corner_ornament" />

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="right|top"
            android:layout_marginRight="2dp"
            android:layout_marginTop="2dp"
            android:scaleType="fitXY"
            android:rotation="90"
            android:src="@drawable/vector_corner_ornament" />

        <!-- Main Content Layout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

        <!-- Actual Padding Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:paddingTop="14dp"
            android:paddingBottom="12dp">

            <!-- Header Row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                
                <TextView
                    android:id="@+id/widget_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jadwal Sholat"
                    android:textColor="#E6C485"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:text="Kota Pekalongan"
                    android:textColor="#8DA09C"
                    android:textSize="12sp" />
            </RelativeLayout>

            <!-- Date Row (Gregorian and Hijri Date) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp">
                
                <TextView
                    android:id="@+id/widget_gregorian_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#8DA09C"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/widget_hijri_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:text="--"
                    android:textColor="#E6C485"
                    android:textSize="10sp" />
            </RelativeLayout>

            <!-- Gradient Divider Line -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="1.5dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/widget_top_accent_gradient" />

            <!-- Main Info (Next Prayer / Ongoing Prayer) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/widget_next_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sholat Berikutnya"
                        android:textColor="#8DA09C"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/widget_next_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Maghrib"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.8"
                    android:orientation="vertical"
                    android:gravity="right">

                    <TextView
                        android:id="@+id/widget_next_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="17:55"
                        android:textColor="#E6C485"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <!-- Diganti Chronometer agar hitung mundur berjalan secara real-time -->
                    <Chronometer
                        android:id="@+id/widget_countdown"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#2EC4B6"
                        android:textSize="11sp"
                        android:textStyle="bold|italic" />
                </LinearLayout>
            </LinearLayout>

            <!-- Footer Row (Prayer times list) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="2dp">

                <!-- Subuh -->
                <LinearLayout
                    android:id="@+id/widget_item_subuh"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="5dp"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/widget_label_subuh"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Subuh"
                        android:textColor="#8DA09C"
                        android:textSize="9sp" />
                    <TextView
                        android:id="@+id/widget_time_subuh"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--:--"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Dzuhur -->
                <LinearLayout
                    android:id="@+id/widget_item_dzuhur"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="5dp"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/widget_label_dzuhur"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dzuhur"
                        android:textColor="#8DA09C"
                        android:textSize="9sp" />
                    <TextView
                        android:id="@+id/widget_time_dzuhur"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--:--"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Ashar -->
                <LinearLayout
                    android:id="@+id/widget_item_ashar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="5dp"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/widget_label_ashar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ashar"
                        android:textColor="#8DA09C"
                        android:textSize="9sp" />
                    <TextView
                        android:id="@+id/widget_time_ashar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--:--"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Maghrib -->
                <LinearLayout
                    android:id="@+id/widget_item_maghrib"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="5dp"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/widget_label_maghrib"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Maghrib"
                        android:textColor="#8DA09C"
                        android:textSize="9sp" />
                    <TextView
                        android:id="@+id/widget_time_maghrib"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--:--"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Isya -->
                <LinearLayout
                    android:id="@+id/widget_item_isya"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="5dp"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/widget_label_isya"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Isya"
                        android:textColor="#8DA09C"
                        android:textSize="9sp" />
                    <TextView
                        android:id="@+id/widget_time_isya"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--:--"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
</FrameLayout>
